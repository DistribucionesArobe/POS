# --- App ---
APP_ENV=development
APP_SECRET_KEY=cambiame-en-produccion-genera-uno-largo
APP_TIMEZONE=America/Mexico_City

# --- Database ---
# Local: postgresql+psycopg2://user:pass@localhost:5432/aceromax
# Render: usar la URL interna que Render expone
DATABASE_URL=postgresql+psycopg2://aceromax:aceromax@localhost:5432/aceromax

# --- Auth (JWT) ---
JWT_SECRET=otra-clave-larga-aleatoria
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Facturama (PAC para CFDI 4.0) ---
# Obtener en https://facturama.mx
FACTURAMA_API_URL=https://api.facturama.mx
FACTURAMA_USER=tu_usuario
FACTURAMA_PASSWORD=tu_password
FACTURAMA_RFC_EMISOR=XAXX010101000
FACTURAMA_REGIMEN_FISCAL=612
FACTURAMA_LUGAR_EXPEDICION=00000

# --- Twilio (WhatsApp) ---
# Linea de Ventas
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VENTAS_FROM=whatsapp:+521XXXXXXXXXX
# Linea de Cobranza
TWILIO_COBRANZA_FROM=whatsapp:+521XXXXXXXXXX

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- CotizaExpress (servicio externo, comparte DB) ---
COTIZAEXPRESS_BASE_URL=https://clawdbot-server.onrender.com
COTIZAEXPRESS_INTERNAL_TOKEN=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
